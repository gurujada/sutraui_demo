<!DOCTYPE html>
<html lang="en" class="scroll-smooth" data-theme="neutral">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Sutra UI" suffix=" - Sutra UI">
      {assigns[:page_title]}
    </.live_title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Geist:wght@400;500;600&family=Geist+Mono&display=swap"
      rel="stylesheet"
    />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        const THEMES = ["neutral", "blue", "green", "rose", "orange", "violet"];
        
        const setMode = (mode) => {
          const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          
          if (mode === "system") {
            localStorage.removeItem("phx:mode");
            document.documentElement.classList.toggle("dark", prefersDark);
          } else {
            localStorage.setItem("phx:mode", mode);
            document.documentElement.classList.toggle("dark", mode === "dark");
          }
        };

        const setTheme = (theme) => {
          if (THEMES.includes(theme)) {
            localStorage.setItem("phx:color-theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };

        const toggleMode = () => {
          const current = localStorage.getItem("phx:mode") || "system";
          const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          const isDark = current === "dark" || (current === "system" && prefersDark);
          setMode(isDark ? "light" : "dark");
        };

        // Initialize on page load
        const savedMode = localStorage.getItem("phx:mode") || localStorage.getItem("phx:theme") || "system";
        const savedTheme = localStorage.getItem("phx:color-theme") || "neutral";
        setMode(savedMode);
        setTheme(savedTheme);

        // Listen for OS theme changes when in system mode
        window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", (e) => {
          if (!localStorage.getItem("phx:mode")) {
            document.documentElement.classList.toggle("dark", e.matches);
          }
        });

        window.addEventListener("storage", (e) => {
          if (e.key === "phx:mode" || e.key === "phx:theme") setMode(e.newValue || "system");
          if (e.key === "phx:color-theme") setTheme(e.newValue || "neutral");
        });
        window.addEventListener("phx:toggle-theme", toggleMode);
        window.addEventListener("phx:set-color-theme", (e) => setTheme(e.detail.theme));
        
        // Bridge for Sutra UI's ThemeSwitcher component
        window.addEventListener("sutra-ui:set-theme", (e) => {
          const theme = e.detail?.theme;
          if (theme === "light" || theme === "dark") {
            setMode(theme);
          } else if (theme === "system") {
            setMode("system");
          }
        });
      })();
    </script>
  </head>
  <body class="bg-background text-foreground antialiased">
    {@inner_content}
  </body>
</html>
